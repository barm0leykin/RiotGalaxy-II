# ===== Сборка .NET / MonoGame =====
# Каталоги сборки на любом уровне вложенности
[Bb]in/
[Oo]bj/

# Артефакты компиляции
*.dll
*.exe
*.pdb
*.dll.config
*.cache
*.cache.*

# Скомпилированный контент MonoGame (.xnb генерируются из исходников в bin/).
# ВНИМАНИЕ: НЕ игнорируем *.xnb глобально — в CocoSharp есть исходные .xnb.
# Достаточно того, что собранный контент лежит в bin/ (уже игнорируется выше).

# Пользовательские файлы MonoGame Content Builder (сам *.mgcb — ИСХОДНИК, его коммитим!)
*.mgcb.user

# ===== Среды разработки =====
# Visual Studio Code
# .vscode/
*.code-workspace

# Rider / JetBrains
.idea/
*.iml
*.iws

# Visual Studio
.vs/
*.suo
*.user
*.sln.docstates

# ===== NuGet =====
*.nupkg
*.snupkg
packages/
!*/packages/repositories.config

# ===== Тесты =====
TestResults/
*.trx
*.coverage
*.coveragexml

# ===== Python (скрипты в tools/) =====
__pycache__/
*.py[cod]

# ===== Docker-сборка (Android) =====
# Пользовательский HOME/кэш контейнера (NuGet, dotnet) — см. docker/*.sh
docker/.home/

# ===== Логи и временные файлы =====
*.log
logs/
*.tmp
*.temp
*.bak
*.backup
*~

# ===== Локальная конфигурация =====
appsettings.local.json
*.local.json
**/Properties/launchSettings.json

# ===== AI-агент / прочее =====
ai-agent/memory/sessions/
ai-agent/sessions/
*.session
.kilo/

# ===== OS =====
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# ===== ВАЖНО: что НЕ игнорируем (нужно в репозитории) =====
# !MonoGame/.config/dotnet-tools.json  — манифест dotnet-mgcb (для `dotnet tool restore`)
# !**/*.mgcb                            — рецепт сборки контента
# !MonoGame/RiotGalaxy.Content/**       — исходные спрайты/звуки/фоны/шрифты
